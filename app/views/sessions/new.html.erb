<div class="animate-fade-in mx-auto" style="max-width: 600px;">
  <!-- Back navigation -->
  <div class="mb-4">
    <%= link_to root_path, class: "text-decoration-none text-muted fw-medium d-inline-flex align-items-center gap-1 hover-lift" do %>
      <i class="bi bi-arrow-left"></i> Cancel and Go Home
    <% end %>
  </div>

  <!-- Header -->
  <div class="text-center mb-4">
    <h1 class="fw-bold"><span class="text-gradient">Log In</span> to AlphaBlog</h1>
    <p class="text-muted">Enter your email and password to access your dashboard.</p>
  </div>

  <!-- Login Card Form -->
  <div class="card card-custom p-4 p-md-5 shadow-sm border-0 bg-body">
    <%= form_with scope: :session, url: login_path, local: true do |f| %>
      <!-- Email Field -->
      <div class="form-group mb-4">
        <%= f.label :email, class: "form-label fw-semibold" %>
        <%= f.email_field :email, 
                          class: "form-control", 
                          placeholder: "Enter your email address",
                          required: true %>
      </div>

      <!-- Password Field -->
      <div class="form-group mb-4">
        <%= f.label :password, class: "form-label fw-semibold" %>
        <%= f.password_field :password, 
                             class: "form-control", 
                             placeholder: "Enter your password",
                             required: true %>
      </div>
      
      <!-- Submission Controls -->
      <div class="d-grid gap-2 mt-4 border-top pt-4">
        <%= f.submit "Log In", class: "btn btn-primary btn-lg rounded-pill fw-semibold shadow-sm hover-lift py-2" %>
      </div>
    <% end %>

    <!-- Bottom links -->
    <div class="text-center mt-4 pt-2 border-top-0">
      <span class="text-muted small">New to AlphaBlog?</span>
      <%= link_to "Sign Up Now", signup_path, class: "small text-decoration-none fw-semibold ms-1" %>
    </div>
  </div>
</div>
