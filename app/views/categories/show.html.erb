<div class="animate-fade-in mx-auto" style="max-width: 800px;">
  <!-- Back navigation -->
  <div class="mb-4">
    <%= link_to categories_path, class: "text-decoration-none text-muted fw-medium d-inline-flex align-items-center gap-1 hover-lift" do %>
      <i class="bi bi-arrow-left"></i> Back to Categories
    <% end %>
  </div>

  <div class="card card-custom p-4 p-md-5 mb-5 shadow-sm text-center border-0 bg-body">
    <div class="d-flex flex-column align-items-center">
      <div class="mb-3">
        <span class="badge bg-primary-subtle text-primary rounded-pill px-4 py-2 fw-bold fs-6">
          <i class="bi bi-tag-fill me-1"></i> Category
        </span>
      </div>
      <h1 class="display-4 fw-extrabold mb-3 text-gradient">Category: <%= @category.name %></h1>
      <% if logged_in? && current_user.admin? %>
        <div class="mt-2">
          <%= link_to edit_category_path(@category), class: "btn btn-outline-primary rounded-pill px-4 fw-semibold hover-lift" do %>
            <i class="bi bi-pencil-square me-1"></i> Edit Category Name
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <h2 class="text-center fw-bold mb-4">Articles</h2>

  <% if @articles && @articles.any? %>
    <div class="d-flex justify-content-center my-4">
      <%== @pagy.series_nav(:bootstrap) %>
    </div>
    <!-- Render articles list -->
    <%= render "articles/article" %>
    
    <div class="d-flex justify-content-center my-4">
      <%== @pagy.series_nav(:bootstrap) %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-5 border rounded-4 bg-body-tertiary">
      <i class="bi bi-journal-x text-muted mb-3" style="font-size: 3rem;"></i>
      <h3 class="fw-bold fs-4">No articles found in this category</h3>
      <p class="text-muted col-md-6 mx-auto mb-0">Articles in this category will show up here once created.</p>
    </div>
  <% end %>
</div>
