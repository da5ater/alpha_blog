<div class="animate-fade-in mx-auto" style="max-width: 700px;">
  <div class="mb-4">
    <%= link_to category_path(@category), class: "text-decoration-none text-muted fw-medium d-inline-flex align-items-center gap-1 hover-lift" do %>
      <i class="bi bi-arrow-left"></i> Back to Category
    <% end %>
  </div>

  <div class="text-center mb-4">
    <h1 class="fw-bold">Edit <span class="text-gradient">Category Name</span></h1>
    <p class="text-muted">Modify the name of the category below.</p>
  </div>

  <div class="card card-custom p-4 p-md-5 shadow-sm border-0 max-width-container mx-auto" style="max-width: 700px;">
    <%= render "form" %>
  </div>
</div>
