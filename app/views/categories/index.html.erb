<div class="animate-fade-in">
  <!-- Index Header -->
  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-5 border-bottom pb-4">
    <div>
      <h1 class="fw-bold mb-1">Categories Directory</h1>
      <p class="text-muted mb-0">
        Browse articles grouped by topic and interest.
      </p>
    </div>
    <% if logged_in? && current_user.admin? %>
      <div>
        <%= link_to new_category_path, class: "btn btn-primary px-4 py-2 rounded-pill fw-semibold shadow-sm d-flex align-items-center gap-2" do %>
          <i class="bi bi-plus-lg"></i> Create New Category
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @categories && @categories.any? %>
    <!-- Pagination Top -->
    <div class="d-flex justify-content-center mb-4">
      <%== @pagy.series_nav(:bootstrap) %>
    </div>

    <!-- Categories Grid -->
    <div class="row g-4 justify-content-center">
      <% @categories.each do |category| %>
        <div class="col-md-6 col-lg-4">
          <div class="card card-custom p-4 text-center h-100 d-flex flex-column justify-content-between">
            <div class="card-body py-3">
              <div class="mb-3">
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1 fw-semibold fs-7">
                  <i class="bi bi-tag-fill me-1"></i> Topic
                </span>
              </div>
              <h4 class="card-title fw-bold mb-2">
                <%= link_to category.name, category_path(category), class: "text-decoration-none text-body text-gradient fw-bold" %>
              </h4>
              <p class="card-text text-muted mb-0 small">
                <%= pluralize(category.articles.count, "article") %>
              </p>
            </div>
            
            <div class="card-footer bg-transparent border-top-0 pt-0 pb-2 px-2 d-flex justify-content-center gap-2">
              <%= link_to "View Category", category_path(category), class: "btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pagination Bottom -->
    <div class="d-flex justify-content-center mt-4">
      <%== @pagy.series_nav(:bootstrap) %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-5 border rounded-4 bg-body-tertiary">
      <i class="bi bi-tags text-muted mb-3" style="font-size: 4rem;"></i>
      <h3 class="fw-bold">No categories found</h3>
      <p class="text-muted col-md-6 mx-auto mb-4">Categories will show up here once created by an admin.</p>
      <% if logged_in? && current_user.admin? %>
        <%= link_to new_category_path, class: "btn btn-primary px-4 py-2 rounded-pill fw-semibold" do %>
          <i class="bi bi-plus-lg"></i> Create First Category
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
