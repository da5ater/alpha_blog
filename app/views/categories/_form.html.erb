<%= render "shared/errors", obj: @category %>

<%= form_with model: @category, local: true do |f| %>
  <!-- Category Name Field -->
  <div class="form-group mb-4">
    <%= f.label :name, "Category Name", class: "form-label fw-semibold" %>
    <%= f.text_field :name, 
                     class: "form-control #{'is-invalid' if @category.errors[:name].any?}", 
                     placeholder: "Enter a name" %>
    <% if @category.errors[:name].any? %>
      <div class="invalid-feedback">
        <%= @category.errors[:name].join(", ") %>
      </div>
    <% end %>
    <div class="form-text text-muted">Category name must be between 3 and 25 characters long and unique.</div>
  </div>
  
  <!-- Submission controls -->
  <div class="d-flex align-items-center justify-content-between gap-3 border-top pt-4 mt-2">
    <%= link_to @category.new_record? ? categories_path : category_path(@category), class: "btn btn-outline-secondary px-4 py-2 rounded-pill fw-semibold hover-lift" do %>
      Cancel
    <% end %>

    <%= f.submit @category.new_record? ? "Create Category" : "Update Category", class: "btn btn-primary px-4 py-2 rounded-pill fw-semibold shadow-sm" %>
  </div>
<% end %>
