<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Alpha Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Alpha Blog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Early theme init script to prevent flashes of light mode -->
    <script>
      (() => {
        'use strict'
        const getStoredTheme = () => localStorage.getItem('theme')
        const getPreferredTheme = () => {
          const storedTheme = getStoredTheme()
          if (storedTheme) return storedTheme
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        }
        document.documentElement.setAttribute('data-bs-theme', getPreferredTheme())
      })()
  </script>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

       <!-- Bootstrap 5.3 Bundle JS with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

  </head>

  <body class="d-flex flex-column min-vh-100 bg-body-tertiary">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top navbar-custom border-bottom py-3">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
          <span class="brand-icon me-2"><i class="bi bi-journal-bookmark-fill text-primary fs-3"></i></span>
          <span class="brand-text fw-bold fs-4 text-gradient">AlphaBlog</span>
        <% end %>
        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center ms-lg-4">
            <li class="nav-item">
              <%= link_to "Home", root_path, class: "nav-link px-3 fw-medium #{'active text-primary' if current_page?(root_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Articles", articles_path, class: "nav-link px-3 fw-medium #{'active text-primary' if current_page?(articles_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Categories", categories_path, class: "nav-link px-3 fw-medium #{'active text-primary' if current_page?(categories_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link px-3 fw-medium #{'active text-primary' if current_page?(about_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Users", users_path, class: "nav-link px-3 fw-medium #{'active text-primary' if current_page?(users_path)}" %>
            </li>

          </ul>
          
          <div class="d-flex align-items-center gap-3">
            <!-- Theme toggle button -->
            <button class="btn btn-theme-toggle rounded-circle border-0 d-flex align-items-center justify-content-center p-2" id="theme-toggle" type="button" aria-label="Toggle theme">
              <i class="bi bi-sun-fill fs-5" id="theme-toggle-icon"></i>
            </button>

            <% if respond_to?(:logged_in?) && logged_in? %>
              <!-- User Settings Dropdown -->
              <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle px-3 py-2 rounded-pill fw-semibold shadow-none d-flex align-items-center gap-2" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="bi bi-person-circle"></i>
                  <% if current_user.respond_to?(:admin?) && current_user.admin? %>
                    <span class="ms-2 text-warning fw-bold"> <%= current_user.username %></span>
                    <span class="badge rounded-pill bg-gradient text-dark ms-2" style="background: linear-gradient(90deg,#ffd54f,#ffb300);">Admin</span>
                  <% else %>
                    <span class="ms-2"><%= current_user.username %></span>
                  <% end %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 p-2 rounded-3" aria-labelledby="userDropdown" style="min-width: 180px;">
                  <li>
                    <%= link_to user_path(current_user), class: "dropdown-item fw-medium py-2 rounded-2 d-flex align-items-center gap-2" do %>
                      <i class="bi bi-person-fill text-muted"></i> View Profile
                    <% end %>
                  </li>
                  <li>  
                    <%= button_to user_path(current_user), method: :delete, data: { confirm: "Are you sure you want to delete your profile?" }, class: "dropdown-item fw-medium py-2 rounded-2 d-flex align-items-center gap-2" do %>
                      <i class="bi bi-gear-fill text-muted"></i> Delete Profile
                    <% end %>
                  </li>
                                    
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= button_to logout_path, method: :delete, class: "dropdown-item text-danger fw-semibold py-2 rounded-2 d-flex align-items-center gap-2 w-100 text-start border-0 bg-transparent" do %>
                      <i class="bi bi-box-arrow-right"></i> Log Out
                    <% end %>
                  </li>
                </ul>
              </div>
            <% else %>
              <!-- Log In Link -->
              <%= link_to login_path, class: "text-decoration-none text-secondary px-3 py-2 fw-semibold hover-lift" do %>
                Log In
              <% end %>

              <!-- Sign Up Link -->
              <%= link_to signup_path, class: "btn btn-outline-primary px-3 py-2 rounded-pill fw-semibold hover-lift" do %>
                Sign Up
              <% end %>
            <% end %>

            <% if logged_in? %>
            <!-- CTA: Create Article -->
            <%= link_to new_article_path, class: "btn btn-primary px-4 py-2 rounded-pill fw-semibold shadow-sm d-flex align-items-center gap-2" do %>
              <i class="bi bi-plus-lg"></i> Create Article
            <% end %>
            <% end %>

          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content Container -->
    <main class="flex-grow-1 container py-5">
      <%= render "layouts/messages" %>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="footer mt-auto py-4 border-top bg-body">
      <div class="container text-center text-md-start">
        <div class="row align-items-center">
          <div class="col-md-6 mb-3 mb-md-0">
            <span class="fw-bold fs-5 text-gradient me-2">AlphaBlog</span>
            <span class="text-muted">© 2026. Made as part of Rails Backend Course.</span>
          </div>
          <div class="col-md-6 text-md-end">
            <%= link_to "Home", root_path, class: "text-decoration-none text-muted me-3" %>
            <%= link_to "Articles", articles_path, class: "text-decoration-none text-muted me-3" %>
            <%= link_to "About", about_path, class: "text-decoration-none text-muted" %>
          </div>
        </div>
      </div>
    </footer>

 
    <!-- Theme Switcher Logic -->
    <script>
      (() => {
        const initTheme = () => {
          const themeToggle = document.getElementById('theme-toggle')
          if (!themeToggle) return

          const themeToggleIcon = document.getElementById('theme-toggle-icon')
          const getStoredTheme = () => localStorage.getItem('theme')
          const setStoredTheme = theme => localStorage.setItem('theme', theme)
          
          const getPreferredTheme = () => {
            const storedTheme = getStoredTheme()
            if (storedTheme) return storedTheme
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
          }

          const setTheme = theme => {
            document.documentElement.setAttribute('data-bs-theme', theme)
            if (theme === 'dark') {
              themeToggleIcon.className = 'bi bi-moon-stars-fill fs-5 text-warning'
              themeToggle.classList.add('btn-dark-mode')
            } else {
              themeToggleIcon.className = 'bi bi-sun-fill fs-5 text-warning'
              themeToggle.classList.remove('btn-dark-mode')
            }
          }

          // Initial theme set
          setTheme(getPreferredTheme())

          // Remove any existing listener to prevent duplicate triggers
          const newThemeToggle = themeToggle.cloneNode(true)
          themeToggle.parentNode.replaceChild(newThemeToggle, themeToggle)

          newThemeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-bs-theme')
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark'
            setTheme(newTheme)
            setStoredTheme(newTheme)
          })
        }

        // Run on DOM load and subsequent Turbo renders
        document.addEventListener('turbo:load', initTheme)
      })()
    </script>
  </body>
</html>
