<% if flash.any? %>
  <div class="container animate-fade-in px-0">
    <% flash.each do |name, msg| %>
      <% 
        alert_class = case name.to_s
                      when 'notice' then 'alert-success'
                      when 'alert', 'error' then 'alert-danger'
                      else 'alert-info'
                      end
        icon_class = case name.to_s
                     when 'notice' then 'bi-check-circle-fill'
                     when 'alert', 'error' then 'bi-exclamation-triangle-fill'
                     else 'bi-info-circle-fill'
                     end
      %>
      <div class="alert <%= alert_class %> alert-dismissible fade show d-flex align-items-center shadow-sm border-0 py-3 px-4 mb-4 rounded-3" role="alert">
        <i class="bi <%= icon_class %> me-3 fs-4"></i>
        <div class="fw-medium">
          <%= msg %>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
  </div>
<% end %>