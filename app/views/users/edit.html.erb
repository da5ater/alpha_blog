<div class="animate-fade-in mx-auto" style="max-width: 700px;">
  <!-- Back navigation -->
  <div class="mb-4">
    <%= link_to articles_path, class: "text-decoration-none text-muted fw-medium d-inline-flex align-items-center gap-1 hover-lift" do %>
      <i class="bi bi-arrow-left"></i> Back to Articles
    <% end %>
  </div>

  <div class="text-center mb-4">
    <h1 class="fw-bold"><span class="text-gradient">Edit</span> Your Profile</h1>
    <p class="text-muted">Update your account username, email, or choose a new password below.</p>
  </div>

  <%= render "form" %>
</div>
