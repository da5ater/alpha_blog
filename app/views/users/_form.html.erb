<div class="card card-custom p-4 p-md-5 shadow-sm border-0 max-width-container mx-auto" style="max-width: 700px;">
  <!-- Shared Error Summary -->
  <%= render "shared/errors", obj: @user %>

  <%= form_with model: @user, local: true do |f| %>
    <!-- Username Field -->
    <div class="form-group mb-4">
      <%= f.label :username, class: "form-label fw-semibold" %>
      <%= f.text_field :username, 
                       class: "form-control #{'is-invalid' if @user.errors[:username].any?}", 
                       placeholder: "Enter a username" %>
      <% if @user.errors[:username].any? %>
        <div class="invalid-feedback">
          <%= @user.errors[:username].join(", ") %>
        </div>
      <% end %>
      <div class="form-text text-muted">Username must be between 3 and 25 characters long.</div>
    </div>
    
    <!-- Email Field -->
    <div class="form-group mb-4">
      <%= f.label :email, class: "form-label fw-semibold" %>
      <%= f.email_field :email, 
                        class: "form-control #{'is-invalid' if @user.errors[:email].any?}", 
                        placeholder: "Enter your email address" %>
      <% if @user.errors[:email].any? %>
        <div class="invalid-feedback">
          <%= @user.errors[:email].join(", ") %>
        </div>
      <% end %>
      <div class="form-text text-muted">Please provide a valid, unique email address.</div>
    </div>

    <!-- Password Field -->
    <div class="form-group mb-4">
      <%= f.label :password, class: "form-label fw-semibold" %>
      <%= f.password_field :password, 
                           class: "form-control #{'is-invalid' if @user.errors[:password].any?}", 
                           placeholder: "Choose a password" %>
      <% if @user.errors[:password].any? %>
        <div class="invalid-feedback">
          <%= @user.errors[:password].join(", ") %>
        </div>
      <% end %>
      <div class="form-text text-muted">Choose a secure, strong password.</div>
    </div>
    
    <!-- Submission controls -->
    <div class="d-flex align-items-center justify-content-between gap-3 border-top pt-4 mt-2">
      <%= link_to articles_path, class: "btn btn-outline-secondary px-4 py-2 rounded-pill fw-semibold hover-lift" do %>
        Cancel
      <% end %>

      <%= f.submit (@user.new_record? ? "Sign Up" : "Update Account"), class: "btn btn-primary px-4 py-2 rounded-pill fw-semibold shadow-sm" %>
    </div>
  <% end %>
</div>
