<div class="animate-fade-in">
  <!-- Index Header -->
  <div class="text-center mb-5 border-bottom pb-4">
    <h1 class="fw-bold mb-1">AlphaBlog Authors</h1>
    <p class="text-muted mb-0">
      Meet the creators contributing to the AlphaBlog directory.
    </p>
  </div>

  <% if @users && @users.any? %>
    <div class="d-flex justify-content-center mb-4">
      <%== @pagy.series_nav(:bootstrap) %>
    </div>


    <!-- Users Grid -->
    <div class="row g-4 justify-content-center">
      <% @users.each do |user| %>
        <div class="col-md-6 col-lg-4">
          <div class="card card-custom p-4 text-center h-100 d-flex flex-column justify-content-between">
            <div class="card-body py-3">
              <!-- User Profile Pravatar -->
              <div class="mb-4">
                <%= pravatar_for user, size: 120 %>
              </div>

              <!-- Username & Details -->
              <h4 class="card-title fw-bold mb-2">
                <%= link_to user.username, user_path(user), class: "text-decoration-none text-body" %>
              </h4>
              <p class="text-muted mb-3"><i class="bi bi-envelope me-1"></i><%= user.email %></p>
              
              <!-- Metrics -->
              <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill px-3 py-2 fw-semibold">
                <i class="bi bi-journals me-1"></i> <%= pluralize(user.articles.count, "article") %>
              </span>
            </div>

            <!-- Footer Action Buttons -->
            <div class="card-footer bg-transparent border-top-0 pt-0 pb-2 px-2 d-flex justify-content-center gap-2">
              <%= link_to "View Profile", user_path(user), class: "btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold" %>
              <% if current_user == user || current_user.admin? %>
              <%= link_to "Edit Profile", edit_user_path(user), class: "btn btn-sm btn-light border rounded-pill px-3 fw-semibold text-secondary" %>
              <%= button_to "Delete Profile", user_path(user), method: :delete , data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-light border rounded-pill px-3 fw-semibold text-secondary" %>
              
              <% end %>    
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-5 border rounded-4 bg-body-tertiary">
      <i class="bi bi-people text-muted mb-3" style="font-size: 4rem;"></i>
      <h3 class="fw-bold">No authors found</h3>
      <p class="text-muted col-md-6 mx-auto mb-4">Be the first to sign up and start publishing.</p>
      <%= link_to signup_path, class: "btn btn-primary px-4 py-2 rounded-pill fw-semibold" do %>
        <i class="bi bi-plus-lg"></i> Sign Up Now
      <% end %>
    </div>
  <% end %>
</div>
