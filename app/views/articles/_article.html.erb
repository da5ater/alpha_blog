<div class="row g-4 animate-fade-in">
  <% @articles.each do |article| %>
    <div class="col-md-6 col-lg-4">
      <div class="card card-custom h-100 d-flex flex-column justify-content-between">
        <div class="card-body">
          <!-- Author Header -->
          <div class="d-flex align-items-center mb-3">
            <% if article.user %>
              <%= link_to user_path(article.user), class: "me-2 hover-lift d-inline-block" do %>
                <%= pravatar_for(article.user, size: 40) %>
              <% end %>
            <% else %>
              <div class="avatar-badge me-2">
                AB
              </div>
            <% end %>
            <div>
              <h6 class="mb-0 fw-bold">
                <% if article.user %>
                  <%= link_to article.user.username, user_path(article.user), class: "text-decoration-none text-body" %>
                <% else %>
                  Anonymous
                <% end %>
              </h6>
              <small class="text-muted"><%= time_ago_in_words(article.created_at) %> ago</small>
            </div>
          </div>

          <!-- Title and Description -->
          <h5 class="card-title fw-bold mb-3">
            <%= link_to article.title, article_path(article), class: "text-decoration-none text-body" %>
          </h5>
          <p class="card-text text-muted mb-4">
            <%= truncate(article.description, length: 150) %>
          </p>
          <% if article.categories.any? %>
            <div class="mb-3 d-flex flex-wrap gap-1">
              <%= render article.categories %>
            </div>
          <% end %>
        </div>

        <!-- Footer Actions -->
        <div class="card-footer bg-transparent border-top-0 pt-0 pb-3 px-3 d-flex justify-content-between align-items-center">
          <%= link_to "Read More", article_path(article), class: "btn btn-sm btn-outline-primary rounded-pill px-3" %>
          <div class="d-flex gap-1">
            <% if logged_in? && (current_user == article.user || current_user.admin?) %>
            <%= link_to edit_article_path(article), class: "btn btn-sm btn-light border p-1 rounded-circle d-flex align-items-center justify-content-center", style: "width: 32px; height: 32px;", title: "Edit" do %>
              <i class="bi bi-pencil-fill text-secondary"></i>
            <% end %>
            <%= button_to article_path(article), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this article?" }, class: "btn btn-sm btn-light border p-1 rounded-circle d-flex align-items-center justify-content-center text-danger", style: "width: 32px; height: 32px;", title: "Delete" do %>
              <i class="bi bi-trash-fill"></i>
            <% end %>
            <% end %>

          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
