<div class="animate-fade-in mx-auto" style="max-width: 800px;">
  <!-- Back navigation -->
  <div class="mb-4">
    <%= link_to articles_path, class: "text-decoration-none text-muted fw-medium d-inline-flex align-items-center gap-1 hover-lift" do %>
      <i class="bi bi-arrow-left"></i> Back to Articles
    <% end %>
  </div>

  <article>
    <!-- Article Header -->
    <header class="mb-4 pb-4 border-bottom">
      <h1 class="display-4 fw-extrabold mb-3"><%= @article.title %></h1>
      
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <!-- Author Profile -->
        <div class="d-flex align-items-center">
          <% if @article.user %>
            <%= link_to user_path(@article.user), class: "me-3 hover-lift d-inline-block" do %>
              <%= pravatar_for(@article.user, size: 48) %>
            <% end %>
          <% else %>
            <div class="avatar-badge me-3" style="width: 48px; height: 48px; font-size: 1.1rem;">
              AB
            </div>
          <% end %>
          <div>
            <h6 class="mb-0 fw-bold fs-5"><%= @article.user&.username || "Anonymous Author" %></h6>
            <small class="text-muted">
              Published <%= @article.created_at.strftime("%B %d, %Y") %>
              <% if @article.created_at != @article.updated_at %>
                • Updated <%= time_ago_in_words(@article.updated_at) %> ago
              <% end %>
            </small>
            <% if @article.categories.any? %>
              <div class="mt-2 d-flex flex-wrap gap-1">
                <%= render @article.categories %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Read time indicator (estimated) -->
        <% word_count = @article.description.split.size %>
        <% read_time = (word_count / 150.0).ceil %>
        <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill px-3 py-2 fw-semibold">
          <i class="bi bi-clock-fill me-1"></i> <%= pluralize(read_time, "minute") %> read
        </span>
      </div>
    </header>

    <!-- Article Content -->
    <div class="card card-custom p-4 p-md-5 mb-5 shadow-sm border-0 bg-body">
      <div class="article-body fs-5 text-body-secondary" style="line-height: 1.8; white-space: pre-line;">
        <%= @article.description %>
      </div>
    </div>

    <!-- Article Footer / Actions -->
    <footer class="d-flex justify-content-between align-items-center p-3 rounded-4 bg-body-secondary shadow-sm">
      <%= link_to articles_path, class: "btn btn-outline-secondary px-4 rounded-pill fw-semibold" do %>
        <i class="bi bi-arrow-left"></i> All Articles
      <% end %>
      
      <div class="d-flex gap-2">
        <% if logged_in? && (current_user == @article.user || current_user.admin?) %>
        <%= link_to edit_article_path(@article), class: "btn btn-light border px-4 rounded-pill fw-semibold hover-lift" do %>
          <i class="bi bi-pencil-fill me-1 text-primary"></i> Edit
        <% end %>
        <%= button_to article_path(@article), method: :delete, data: { turbo_confirm: "Are you sure you want to permanently delete this article?" }, class: "btn btn-danger px-4 rounded-pill fw-semibold hover-lift" do %>
          <i class="bi bi-trash-fill me-1"></i> Delete
        <% end %>
        <% end %>
      </div>
    </footer>
  </article>
</div>