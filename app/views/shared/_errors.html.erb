<% if obj && obj.errors.any? %>
  <div class="alert alert-danger alert-dismissible fade show border-0 py-3 mb-4 rounded-3 d-flex align-items-start animate-fade-in" role="alert">
    <i class="bi bi-exclamation-octagon-fill me-3 fs-4 mt-1"></i>
    <div>
      <h5 class="alert-heading fw-bold mb-1">
        <%= pluralize(obj.errors.count, "error") %> prohibited this action:
      </h5>
      <ul class="mb-0 ps-3">
        <% obj.errors.full_messages.each do |message| %>
          <li class="small"><%= message %></li>
        <% end %>
      </ul>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>
